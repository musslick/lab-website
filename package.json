{
  "name": "automated-lab",
  "version": "1.0.0",
  "description": "Website for the Automated Scientific Discovery of Mind and Brain lab.",
  "main": "src/App.tsx",
  "homepage": "https://www.ai4cogsci.com/",
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "predeploy": "npm run build && cp build/index.html build/404.html && echo 'www.ai4cogsci.com' > build/CNAME",
    "deploy": "gh-pages -d build",
    "deploy:firebase": "npm run build && firebase deploy",
    "migrate-data": "tsx scripts/migrateData.ts"
  },
  "dependencies": {
    "firebase": "^10.13.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.15.0",
    "react-scripts": "5.0.1"
  },
  "devDependencies": {
    "@types/node": "^16.18.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.6.1",
    "firebase-tools": "^13.0.0",
    "gh-pages": "^6.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^4.9.5"
  },
  "keywords": [
    "scientific",
    "lab",
    "website",
    "react"
  ],
  "author": "Your Name",
  "license": "MIT",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
